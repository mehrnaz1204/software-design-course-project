@startuml

' ====== تعریف بازیگران (موجودیت‌های خارجی) ======
actor "راننده" as Driver
actor "دوربین پلاک خوان" as Camera
actor "اپراتور ورودی" as EntryOp
actor "اپراتور خروجی" as ExitOp
actor "مدیر مالی" as FinMgr
actor "مدیر فنی" as TechMgr
actor "سامانه پلیس" as Police
actor "سامانه پیامک" as SMS
actor "سیستم بانک" as Bank

' ====== سیستم اصلی ======
rectangle "سیستم کنترل ورود/خروج" {
  
  ' یوزکیس‌ها (قابلیت‌های سیستم)
  usecase "بررسی پلاک خودرو" as UC1
  usecase "استعلام وضعیت پلاک" as UC2
  usecase "تأیید ورود عادی" as UC3
  usecase "ثبت زمان ورود" as UC4
  usecase "ثبت تردد" as UC5
  usecase "محاسبه هزینه خروج" as UC6
  usecase "پرداخت هزینه" as UC7
  usecase "تأیید خروج اضطراری" as UC8
  usecase "ثبت خروج اضطراری" as UC9
  usecase "مدیریت خودروهای مجاز" as UC10
  usecase "گزارش مالی" as UC11
  usecase "گزارش فنی" as UC12
}

' ====== ارتباط بازیگران با یوزکیس‌ها ======

' راننده
Driver --> UC1
Driver --> UC6
Driver --> UC7
Driver --> UC9

' دوربین
Camera --> UC1

' اپراتور ورودی
EntryOp --> UC3

' اپراتور خروجی
ExitOp --> UC8

' مدیر مالی
FinMgr --> UC11

' مدیر فنی
TechMgr --> UC10
TechMgr --> UC12

' سامانه پلیس
Police --> UC2

' سامانه پیامک
SMS --> UC7

' سیستم بانک
Bank --> UC7

' ====== ارتباط بین یوزکیس‌ها (<<include>> و <<extend>>) ======

' UC1 (بررسی پلاک) همیشه شامل UC2 (استعلام) است
UC1 ..> UC2 : <<include>>

' UC3 (تأیید ورود) فقط بعد از UC1 انجام می‌شود
UC1 ..> UC3 : <<include>>

' UC4 (ثبت زمان ورود) همیشه با UC3 همراه است
UC3 ..> UC4 : <<include>>

' UC5 (ثبت تردد) شامل ذخیره در مخزن است
UC4 ..> UC5 : <<include>>

' UC6 (محاسبه هزینه) برای خروج عادی انجام می‌شود
UC5 ..> UC6 : <<extend>>

' UC7 (پرداخت) همیشه با UC6 همراه است
UC6 ..> UC7 : <<include>>

' UC8 (تأیید خروج اضطراری) مستقل است
UC8 ..> UC9 : <<include>>

' UC9 (ثبت خروج اضطراری) به صورت جداگانه ثبت می‌شود

' UC10 (مدیریت خودروهای مجاز) فقط برای مدیر فنی است
' UC11 (گزارش مالی) فقط برای مدیر مالی است
' UC12 (گزارش فنی) فقط برای مدیر فنی است

@enduml
